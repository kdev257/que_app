y h3 *, #ot-sync-ntfy h4 *, #ot-sync-ntfy h6 *, #ot-sync-ntfy button *, #ot=
-sync-ntfy a[data-parent-id] * { font-size: inherit; font-weight: inherit; =
color: inherit; }

