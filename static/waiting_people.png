#onetrust-pc-sdk .ot-sdk-container { padding-right: 0px; }

#onetrust-pc-sdk .ot-sdk-row { flex-direction: initial; width: 100%; }

#onetrust-pc-sdk [type=3D"checkbox"]:checked, #onetrust-pc-sdk [type=3D"che=
ckbox"]:not(:checked) { pointer-events: initial; }

#onetrust-pc-sdk [type=3D"checkbox"]:disabled + label::before, #onetrust-pc=
-sdk [type=3D"checkbox"]:disabled + label::after, #onetrust-pc-sdk [type=3D=
"checkbox"]:disabled + label { pointer-events: none; opacity: 0.7; }

