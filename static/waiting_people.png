#onetrust-pc-sdk .pc-logo, #onetrust-pc-sdk .ot-pc-logo { height: 60px; wid=
th: 180px; background-position: center center; background-size: contain; ba=
ckground-repeat: no-repeat; display: inline-flex; justify-content: center; =
align-items: center; }

#onetrust-pc-sdk .pc-logo img, #onetrust-pc-sdk .ot-pc-logo img { max-heigh=
t: 100%; max-width: 100%; }

